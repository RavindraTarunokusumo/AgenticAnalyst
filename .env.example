# DashScope provider (OpenAI-compatible endpoint)
MODEL_PROVIDER=dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# OpenRouter provider (set MODEL_PROVIDER=openrouter; never commit a real key)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FRONTIER_MODEL=tencent/hy3:free
# Alternative frontier model: nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_BATCH_SUMMARY_MODEL=cohere/north-mini-code:free
# Alternative batch model: google/gemma-4-31b-it:free
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=3

# PostgreSQL system of record
POSTGRES_DB=analyst_engine
POSTGRES_USER=analyst_engine
POSTGRES_PASSWORD=
DATABASE_URL=

# Self-hosted SearXNG (used by Docker Compose only)
SEARXNG_SECRET_KEY=
SEARXNG_PUBLIC_BASE_URL=http://localhost:8080/

# LangSmith observability (disabled by default in local development and tests)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=analyst-engine-local
LANGSMITH_ENDPOINT=

# Application process mode: api | scheduler
APP_PROCESS_MODE=api

# RSS/Atom ingestion, batching, and pipeline tuning (all optional; defaults shown)
FEED_REQUEST_TIMEOUT_SECONDS=15.0
FEED_RESPONSE_SIZE_LIMIT_BYTES=5000000
FEED_USER_AGENT=AnalystEngine/0.1 (+https://github.com/RavindraTarunokusumo/AgenticAnalyst)
DEFAULT_POLL_INTERVAL_MINUTES=30
ARTICLE_MIN_CONTENT_LENGTH=200
ARTICLE_MAX_RESPONSE_SIZE_BYTES=10000000
ALLOWED_LANGUAGES=["en"]
TITLE_SIMILARITY_THRESHOLD=0.35
GROUPING_ALGORITHM_VERSION=v1
BATCH_SUMMARY_PROMPT_VERSION=v1
MAX_FEEDS_PER_RUN=50
MAX_ARTICLES_PER_RUN=200
# Local-development-only opt-in; must stay false outside local development
ALLOW_UNAUTHENTICATED_WRITE=false

# Opt-in temporal holdout evaluation (outside routine CI)
TEMPORAL_EVALUATION_ENABLED=false
TEMPORAL_EVALUATION_MODEL=qwen3.7-max-preview
TEMPORAL_EVALUATION_CUTOFF_DATE=
TEMPORAL_EVALUATION_CORPUS_PATH=
