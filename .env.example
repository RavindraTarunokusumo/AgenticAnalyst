# DashScope provider (OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# PostgreSQL system of record
DATABASE_URL=

# LangSmith observability (disabled by default in local development and tests)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=analyst-engine-local
LANGSMITH_ENDPOINT=

# Application process mode: api | scheduler
APP_PROCESS_MODE=api

# Opt-in temporal holdout evaluation (outside routine CI)
TEMPORAL_EVALUATION_ENABLED=false
TEMPORAL_EVALUATION_MODEL=qwen3.7-max-preview
TEMPORAL_EVALUATION_CUTOFF_DATE=
TEMPORAL_EVALUATION_CORPUS_PATH=
